{
  "name": "spark-ai",
  "version": "0.1.0",
  "description": "AI星火 - Monorepo 全栈 AI Agent 应用",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @spark/types build && pnpm -r --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter @spark/web dev",
    "dev:server": "pnpm --filter @spark/types build && pnpm --filter @spark/server dev",
    "build": "pnpm -r build",
    "start": "pnpm -r --parallel --filter \"./apps/*\" start",
    "start:web": "pnpm --filter @spark/web start",
    "start:server": "pnpm --filter @spark/server start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
